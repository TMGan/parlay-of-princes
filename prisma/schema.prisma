generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(USER)
  inviteCodeUsed String?
  pointAdjustments PointAdjustment[]
  
  avatarUrl   String?

  totalPoints Int @default(0)
  betsWon     Int @default(0)
  betsLost    Int @default(0)
  biggestHit  Int @default(0)

  // Admin-managed overrides — persisted across stat recalculations
  betsWonOffset      Int  @default(0) // added to derived betsWon (can be negative)
  biggestHitOverride Int?             // if set, replaces derived biggestHit
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  bets Bet[]
  leagueMemberships LeagueMember[] @relation("LeagueMemberships")
  createdLeagues    League[]       @relation("LeagueCreator")
  messages          Message[]      @relation("UserMessages")

  @@index([totalPoints])
  @@index([username])
}

enum Role {
  USER
  ADMIN
}

model Bet {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which league this bet belongs to (null = legacy / pre-migration bets)
  leagueId    String?
  league      League?    @relation("LeagueBets", fields: [leagueId], references: [id])

  weekNumber  Int
  sport       String
  description String

  oddsAmerican Int
  oddsLocked   Int

  isKingLock    Boolean @default(false)
  isBonusBet    Boolean @default(false)
  bonusBetId    String?

  status         BetStatus @default(PENDING)
  pointsAwarded  Int?

  // Compressed JPEG data URL of the bet slip screenshot (stored by the user at bet creation)
  betSlipImage  String?

  gameStartTime DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resolvedAt    DateTime?

  @@index([userId, weekNumber, leagueId])
  @@index([leagueId])
  @@index([status])
  @@index([gameStartTime])
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOIDED
}

model League {
  id          String         @id @default(cuid())
  name        String
  description String?
  creatorId   String
  creator     User           @relation("LeagueCreator", fields: [creatorId], references: [id])
  isPublic    Boolean        @default(false)
  joinCode    String         @unique
  minMembers  Int            @default(3)
  maxMembers  Int            @default(20)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members          LeagueMember[]
  messages         Message[]
  activities       LeagueActivity[]
  bets             Bet[]              @relation("LeagueBets")
  pointAdjustments PointAdjustment[]  @relation("LeaguePointAdjustments")

  @@index([joinCode])
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation("LeagueMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER") // "MEMBER" or "ADMIN"
  status   String   @default("ACTIVE") // "PENDING", "ACTIVE", "REMOVED"
  joinedAt DateTime @default(now())

  // Per-league stats — recalculated from bets placed after joinedAt
  leaguePoints     Int @default(0)
  leagueBetsWon    Int @default(0)
  leagueBetsLost   Int @default(0)
  leagueBiggestHit Int @default(0)

  // Admin-managed overrides — persisted across stat recalculations
  leagueBetsWonOffset      Int  @default(0)
  leagueBiggestHitOverride Int?

  @@unique([leagueId, userId])
  @@index([userId])
  @@index([leagueId])
}

model Message {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserMessages", fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([leagueId])
  @@index([userId])
}

model LeagueActivity {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId    String
  username  String
  type      String   // "BET_WON" | "BET_LOST" | "BET_VOIDED" | "MEMBER_JOINED"
  message   String
  points    Int?
  createdAt DateTime @default(now())

  @@index([leagueId, createdAt])
}

model BonusBet {
  id          String   @id @default(cuid())
  name        String                    // e.g. "Dinger Tuesday"
  description String                    // Admin's event parameters/category
  sport       String   @default("")    // e.g. "MLB", "Tennis"

  availableDate DateTime
  expiryDate    DateTime

  createdByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([availableDate, expiryDate])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  usedBy    String?
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  usedAt    DateTime?
  
  @@index([code])
}

model PointAdjustment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagueId    String?
  league      League?  @relation("LeaguePointAdjustments", fields: [leagueId], references: [id], onDelete: SetNull)
  adjustedBy  String
  amount      Int
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([leagueId])
}
